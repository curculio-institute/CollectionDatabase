# Data directory — DB and config are never committed
data/
*.db
*.db-shm
*.db-wal
*.sqlite

# Python bytecode
__pycache__/
*.py[cod]

# Test cache
.pytest_cache/

# Editor swap/backup files
*.kate-swp
*.swp
*~

# TaxonWorks API token
~/.config/tw_token

# Environment / secrets
.env

# Misc
# Ignore stray PNGs (screenshots etc.) but keep the app's own static assets:
# the UI background and the favicon are referenced by the app and must ship.
*.png
!app/static/beetle_white.png
!app/static/collection_icon.png
